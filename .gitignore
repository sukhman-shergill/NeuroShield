# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# ──────────────────────────────────────────────
# Project runtime artifacts
# ──────────────────────────────────────────────
logs/
outputs/
data/processed/
scratch/

# Raw dataset (auto-downloaded at runtime)
data/raw/

# ──────────────────────────────────────────────
# Node.js / Frontend
# ──────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/assets/.aistudio/
*.log
npm-debug.log*

# ──────────────────────────────────────────────
# IDE & OS
# ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
# Environment & secrets
# ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ──────────────────────────────────────────────
# Trained model artifacts (tracked via Git LFS or GitHub Releases)
# Uncomment below to commit small models directly:
# !models/*.keras
# !models/*.joblib
# !models/*.json
# ──────────────────────────────────────────────
models/*.keras
models/*.joblib

# ──────────────────────────────────────────────
# UNSW-NB15 dataset files (large CSVs — do not commit)
# ──────────────────────────────────────────────
data/raw/UNSW_NB15_*.csv
